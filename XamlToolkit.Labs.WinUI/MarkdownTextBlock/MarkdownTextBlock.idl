import "MarkdownTextBlock/LinkClickedEventArgs.idl";
import "MarkdownTextBlock/MarkdownConfig.idl";

namespace XamlToolkit.Labs.WinUI
{
    [default_interface]
    runtimeclass MarkdownTextBlock : Microsoft.UI.Xaml.Controls.Control
    {
        MarkdownTextBlock();

        XamlToolkit.Labs.WinUI.MarkdownConfig Config{ get; set; };
        String Text{ get; set; };
        Boolean IsTextSelectionEnabled{ get; set; };

        static Microsoft.UI.Xaml.DependencyProperty ConfigProperty{ get; };
        static Microsoft.UI.Xaml.DependencyProperty TextProperty{ get; };
        static Microsoft.UI.Xaml.DependencyProperty IsTextSelectionEnabledProperty{ get; };

        event Windows.Foundation.EventHandler<LinkClickedEventArgs> OnLinkClicked;
    }
}