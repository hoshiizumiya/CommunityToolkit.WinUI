import "Xaml/Activities/Activity.idl";
import "Xaml/AnimationSet.idl";

namespace XamlToolkit.WinUI.Animations
{
    /// <summary>
    /// An activity that starts a specified animation.
    /// </summary>
    runtimeclass StartAnimationActivity : Activity
    {
        StartAnimationActivity();

        /// <summary>
        /// Gets or sets the linked <see cref="AnimationSet"/> instance to start.
        /// </summary>
        AnimationSet Animation;

		static Microsoft.UI.Xaml.DependencyProperty AnimationProperty{ get; };

        /// <summary>
        /// Gets or sets the object to start the specified animation on. If not specified, will use the current object the parent animation is running on.
        /// </summary>
		Microsoft.UI.Xaml.UIElement TargetObject;

		static Microsoft.UI.Xaml.DependencyProperty TargetObjectProperty{ get; };
    }
}
