namespace XamlToolkit.WinUI.Behaviors
{
    /// <summary>
    /// Performs an animation on a ListView or GridView Header to make it quick return using composition.
    /// </summary>
    runtimeclass QuickReturnHeaderBehavior : Microsoft.UI.Xaml.DependencyObject, XamlToolkit.WinUI.Interactivity.IBehavior
    {
        QuickReturnHeaderBehavior();

        /// <summary>
        /// Show the header
        /// </summary>
        void Show();
    }
}